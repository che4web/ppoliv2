{{define "base"}}
<!doctype html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Poliv59 — интернет-магазин автополива</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
  <link rel="stylesheet" href="/static/css/style.css">
</head>
<body>
  <header class="site-header">
    <div class="container">
      <div class="topbar">
        <a href="#" class="brand text-decoration-none">
          <span class="brand-mark">
            <svg viewBox="0 0 48 48" aria-hidden="true">
              <path d="M23 6C14 14 9 20 9 27a15 15 0 0 0 30 0c0-7-6-14-16-21z" fill="#2da447"/>
              <path d="M27 9c2 10-1 17-8 21 8 2 16-3 20-13-2-3-6-6-12-8z" fill="#0b8fcb"/>
            </svg>
          </span>
          <span>
            <span class="brand-name">POLIV59</span>
            <span class="brand-subtitle">системы автополива</span>
          </span>
        </a>

        <div class="topbar-item d-none d-lg-flex">
          <span class="icon-badge">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21s7-5.9 7-11a7 7 0 1 0-14 0c0 5.1 7 11 7 11zm0-8.2a2.8 2.8 0 1 1 0-5.6 2.8 2.8 0 0 1 0 5.6z" fill="currentColor"/></svg>
          </span>
          <span>г. Москва, ул. Профсоюзная, 76</span>
        </div>

        <a class="topbar-phone text-decoration-none" href="tel:+74951234567">+7 (495) 123-45-67</a>

        <div class="topbar-actions">
          <a href="#" class="action-link text-decoration-none">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M10 18a8 8 0 1 1 5.3-14l5 5-1.5 1.5-5-5A6 6 0 1 0 16 10h2a8 8 0 0 1-8 8z" fill="currentColor"/></svg>
            Поиск
          </a>
          <a href="#" class="action-link text-decoration-none d-none d-md-inline-flex">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4zm0 2c-4 0-7 2-7 4.5V20h14v-1.5C19 16 16 14 12 14z" fill="currentColor"/></svg>
            Войти
          </a>
          <a href="#" class="action-link text-decoration-none">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 6h14l-1.6 8.2a2 2 0 0 1-2 1.6H10a2 2 0 0 1-2-1.6L6.2 4H3V2h4l.8 4zm3 14a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3zm7 0a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3z" fill="currentColor"/></svg>
            Корзина
            <span class="cart-count">3</span>
          </a>
        </div>
      </div>
    </div>

    <div class="menu-strip">
      <div class="container">
        <nav class="main-nav">
          <a class="catalog-btn text-decoration-none" href="#">
            <span class="burger" aria-hidden="true"><span></span></span>
            Каталог товаров
          </a>
          <a href="#">Готовые решения</a>
          <a href="#">Монтаж</a>
          <a href="#">Блог</a>
          <a href="#">Доставка и оплата</a>
          <a href="#">Контакты</a>
        </nav>
      </div>
    </div>
  </header>

  <main class="page-shell">
    <section class="hero-section">
      <div class="hero-banner">
        <div class="hero-copy">
          <h1>Автоматический<br>полив <span>без забот</span></h1>
          <p>Экономьте воду и время с умными системами полива</p>
          <div class="hero-actions">
            <a href="#" class="btn btn-success btn-main">Подобрать систему</a>
            <a href="#" class="btn btn-light btn-catalog">Каталог товаров</a>
          </div>
        </div>
        <img src="/static/img/hero-top.png" alt="Автоматический полив газона дождевателями" class="hero-scene">
      </div>
    </section>

    <section class="container category-grid-wrap">
      <div class="category-grid">
        {{range $index, $card := .HeroCards}}
        <article class="category-card">
          <div class="category-copy">
            <h2>{{$card.Title}}</h2>
            <p>{{$card.Description}}</p>
            <a href="#">{{$card.LinkText}} <span aria-hidden="true">→</span></a>
          </div>
          <img
            src="{{if eq $index 0}}/static/img/category-photo-1c.png{{else if eq $index 1}}/static/img/product-photo-2.png{{else if eq $index 2}}/static/img/product-photo-3.png{{else}}/static/img/product-photo-4.png{{end}}"
            alt="{{$card.Title}}"
            class="category-art{{if eq $index 0}} category-art-right{{end}}"
          >
        </article>
        {{end}}
      </div>
    </section>

    <section class="feature-strip">
      <div class="container">
        <div class="feature-grid">
          {{range $index, $feature := .Features}}
          <article class="feature-item">
            <span class="feature-icon">
              {{if eq $index 0}}
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2C8 6.4 6 9.4 6 12.7A6 6 0 0 0 18 13c0-3.3-2.4-6.3-6-11zM9.7 14.7a3.1 3.1 0 0 0 3.2 2.5c1.2 0 2.2-.5 3-1.3" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {{else if eq $index 1}}
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M2 8a13 13 0 0 1 20 0M5 11a9 9 0 0 1 14 0M8.5 14.5a5 5 0 0 1 7 0M12 18h.01" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"/></svg>
              {{else if eq $index 2}}
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m14 4 6 6m-4-8-8 8m-3 3-2 7 7-2 10-10-5-5L5 13z" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {{else}}
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 20c4.7-3 7-6.1 7-9.4A4.5 4.5 0 0 0 14.5 6c-1 0-1.8.3-2.5 1-.7-.7-1.6-1-2.5-1A4.5 4.5 0 0 0 5 10.6C5 13.9 7.3 17 12 20z" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {{end}}
            </span>
            <p class="feature-text">
              {{if eq $index 0}}
              <span>Экономия воды</span>
              <strong>до 50%</strong>
              {{else if eq $index 1}}
              <span>Автоматизация</span>
              <strong>и Wi‑Fi управление</strong>
              {{else if eq $index 2}}
              <span>Простая установка</span>
              <strong>своими руками</strong>
              {{else}}
              <span>Подходит для любого</span>
              <strong>участка и растений</strong>
              {{end}}
            </p>
          </article>
          {{end}}
        </div>
      </div>
    </section>

    <section class="container section-spaced steps-section">
      <h2 class="section-title">Как это работает?</h2>
      <div class="steps-row steps-row-mockup">
        {{range $index, $step := .Steps}}
        <article class="step-card step-card-mockup">
          <div class="step-topline">
            <div class="step-badge">{{$step.Number}}</div>
            <img
              src="{{if eq $index 0}}/static/img/icon1-refined.png{{else if eq $index 1}}/static/img/icon2-refined.png{{else if eq $index 2}}/static/img/icon3-refined.png{{else}}/static/img/icon4-refined.png{{end}}"
              alt=""
              class="step-icon-image"
            >
          </div>
          <p class="step-text">{{$step.Title}}</p>
        </article>
        {{if lt $index 3}}
        <span class="step-arrow" aria-hidden="true">→</span>
        {{end}}
        {{end}}
      </div>
    </section>

    <section class="container section-spaced">
      <div class="section-heading">
        <h2 class="section-title mb-0">Популярные товары</h2>
        <a href="#" class="section-link">Смотреть все <span aria-hidden="true">→</span></a>
      </div>

      <div class="products-layout">
        <div class="products-grid">
          {{range $index, $product := .Products}}
          <article class="product-card">
            <div class="product-media">
              <img
                src="{{if eq $index 0}}/static/img/product-photo-1.png{{else if eq $index 1}}/static/img/product-photo-2.png{{else if eq $index 2}}/static/img/product-photo-3.png{{else}}/static/img/product-photo-4.png{{end}}"
                alt="{{$product.Name}}"
                class="product-image"
              >
            </div>
            <div class="product-body">
              <h3>{{$product.Name}}</h3>
              <p class="product-meta">{{$product.Meta}}</p>
              <p class="product-price">{{$product.Price}}</p>
              <div class="product-actions">
                <a href="#" class="btn btn-success btn-sm">В корзину</a>
                <button class="wishlist-btn" type="button" aria-label="Добавить в избранное">
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 20c4.7-3 7-6.1 7-9.4A4.5 4.5 0 0 0 14.5 6c-1 0-1.8.3-2.5 1-.7-.7-1.6-1-2.5-1A4.5 4.5 0 0 0 5 10.6C5 13.9 7.3 17 12 20z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
              </div>
            </div>
          </article>
          {{end}}
        </div>

        <aside class="selector-card">
          <h3>Подберем систему полива за 1 минуту</h3>
          <form class="selector-form">
            <select class="form-select"><option>Площадь участка</option></select>
            <select class="form-select"><option>Тип растений</option></select>
            <select class="form-select"><option>Источник воды</option></select>
            <button class="btn btn-light" type="button">Получить решение</button>
          </form>
        </aside>
      </div>
    </section>

    <section class="container section-spaced section-reviews">
      <div class="section-heading">
        <h2 class="section-title mb-0">Отзывы клиентов</h2>
        <a href="#" class="section-link">Смотреть все отзывы <span aria-hidden="true">→</span></a>
      </div>

      <div class="reviews-layout">
        <div class="reviews-grid">
          {{range $index, $review := .Reviews}}
          <article class="review-card">
            <div class="review-stars">★★★★★</div>
            <p class="review-text">{{$review.Text}}</p>
            <div class="review-meta">
              <div class="review-avatar {{if eq $index 0}}review-avatar-one{{else}}review-avatar-two{{end}}"></div>
              <div>
                <p class="review-author">{{$review.Author}}</p>
                <p class="review-date">{{$review.Date}}</p>
              </div>
            </div>
          </article>
          {{end}}
        </div>

        <aside class="consult-card">
          <div class="consult-head">
            <span class="consult-icon">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16v9H8l-4 4V6zm5 4h6M8 10h.01" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <div>
              <h3>Нужна помощь с выбором?</h3>
              <p>Наши специалисты помогут подобрать лучшее решение</p>
            </div>
          </div>
          <a href="tel:+74951234567" class="consult-phone text-decoration-none">+7 (495) 123-45-67</a>
          <a href="#" class="btn btn-outline-success">Получить консультацию</a>
        </aside>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-grid">
      <div>
        <a href="#" class="brand brand-footer text-decoration-none">
          <span class="brand-mark">
            <svg viewBox="0 0 48 48" aria-hidden="true">
              <path d="M23 6C14 14 9 20 9 27a15 15 0 0 0 30 0c0-7-6-14-16-21z" fill="#2da447"/>
              <path d="M27 9c2 10-1 17-8 21 8 2 16-3 20-13-2-3-6-6-12-8z" fill="#0b8fcb"/>
            </svg>
          </span>
          <span>
            <span class="brand-name">POLIV59</span>
            <span class="brand-subtitle">системы автополива</span>
          </span>
        </a>
        <p class="footer-about">Интернет-магазин систем автоматического полива и комплектующих.</p>
        <div class="social-row">
          <a href="#" aria-label="ВКонтакте">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5h3.2c.2 3.3 1.4 5.3 2.4 5.7V5H13v3.2c1-.1 2.1-2 2.5-3.2H19c-.6 1.8-1.9 3.5-3 4.2 1.3.6 2.7 2.2 3.5 4.8h-3.8c-.4-1.1-1.4-2.8-2.7-2.9V14h-3.4v-2.5C8.2 11.9 6.2 9.4 4 5z" fill="currentColor"/></svg>
          </a>
          <a href="#" aria-label="Telegram">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m20 4-2.8 14.2c-.2 1-1 .9-1.5.6l-4.1-3-2 2c-.2.3-.4.4-.8.4l.3-4.3L17 7.3c.4-.4-.1-.6-.6-.3L6.7 13 2.6 11.7c-.9-.3-.9-.9.2-1.3L19 4.2c.7-.3 1.3.2 1 .8z" fill="currentColor"/></svg>
          </a>
          <a href="#" aria-label="YouTube">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 8.5a2.8 2.8 0 0 0-2-2c-1.7-.5-7-.5-7-.5s-5.3 0-7 .5a2.8 2.8 0 0 0-2 2A29 29 0 0 0 2.5 12a29 29 0 0 0 .5 3.5 2.8 2.8 0 0 0 2 2c1.7.5 7 .5 7 .5s5.3 0 7-.5a2.8 2.8 0 0 0 2-2 29 29 0 0 0 .5-3.5 29 29 0 0 0-.5-3.5zM10 15.3V8.7l5.7 3.3-5.7 3.3z" fill="currentColor"/></svg>
          </a>
        </div>
      </div>

      <div>
        <h4>Каталог</h4>
        <ul class="footer-links">
          <li><a href="#">Капельный полив</a></li>
          <li><a href="#">Дождеватели</a></li>
          <li><a href="#">Контроллеры</a></li>
          <li><a href="#">Трубы и фитинги</a></li>
        </ul>
      </div>

      <div>
        <h4>Покупателям</h4>
        <ul class="footer-links">
          <li><a href="#">Готовые решения</a></li>
          <li><a href="#">Монтаж</a></li>
          <li><a href="#">Доставка и оплата</a></li>
          <li><a href="#">Гарантия и возврат</a></li>
        </ul>
      </div>

      <div>
        <h4>Контакты</h4>
        <ul class="footer-links">
          <li>г. Москва,<br>ул. Профсоюзная, 76</li>
          <li><a href="tel:+74951234567">+7 (495) 123-45-67</a></li>
          <li><a href="mailto:info@poliv59.ru">info@poliv59.ru</a></li>
        </ul>
      </div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>
{{end}}
