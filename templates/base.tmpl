{{define "base"}}
<!doctype html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>AquaGreen — интернет-магазин автополива</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
  <link rel="stylesheet" href="/static/css/style.css">
</head>
<body class="bg-body-tertiary">
  <header class="border-bottom bg-white sticky-top">
    <div class="container py-3">
      <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <a href="#" class="navbar-brand fw-bold fs-3 mb-0 text-uppercase">Aqua<span class="text-success">Green</span></a>

        <div class="contact-chip d-none d-lg-flex align-items-center gap-2 px-3 py-2 rounded-3 bg-light">
          <span class="small">📍</span>
          <div class="small">
            <div class="fw-semibold">г. Москва, ул. Профсоюзная, 76</div>
            <div class="text-secondary">Пн–Пт: 9:00–18:00</div>
          </div>
        </div>

        <a class="fw-bold text-dark text-decoration-none fs-5" href="tel:+74951234567">+7 (495) 123-45-67</a>
      </div>

      <nav class="d-flex flex-wrap gap-3 fw-semibold small mt-3">
        <a class="link-dark text-decoration-none" href="#">Каталог товаров</a>
        <a class="link-dark text-decoration-none" href="#">Готовые решения</a>
        <a class="link-dark text-decoration-none" href="#">Монтаж</a>
        <a class="link-dark text-decoration-none" href="#">Блог</a>
        <a class="link-dark text-decoration-none" href="#">Доставка и оплата</a>
        <a class="link-dark text-decoration-none" href="#">Контакты</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="container my-4">
      <div class="hero p-4 p-lg-5 rounded-4 text-white position-relative overflow-hidden">
        <div class="row align-items-center g-4">
          <div class="col-lg-6">
            <h1 class="display-4 fw-bold mb-3">Автоматический полив <span class="text-warning-emphasis">без забот</span></h1>
            <p class="lead mb-4">Экономьте воду и время с умными системами полива.</p>
            <div class="d-flex flex-wrap gap-2">
              <button class="btn btn-success btn-lg px-4">Подобрать систему</button>
              <button class="btn btn-light btn-lg px-4">Каталог товаров</button>
            </div>
          </div>
          <div class="col-lg-6">
            <img src="/static/img/hero-irrigation.svg" alt="Система автополива на газоне" class="img-fluid rounded-4 hero-image">
          </div>
        </div>
      </div>
    </section>

    <section class="container mb-4">
      <div class="row g-3">
        {{range .HeroCards}}
        <div class="col-12 col-md-6 col-xl-3">
          <article class="card shadow-sm h-100 border-0">
            <div class="card-body">
              <h3 class="h5 fw-bold">{{.Title}}</h3>
              <p class="text-secondary">{{.Description}}</p>
              <a href="#" class="link-success text-decoration-none fw-semibold">{{.LinkText}} →</a>
            </div>
          </article>
        </div>
        {{end}}
      </div>
    </section>

    <section class="bg-light border-top border-bottom py-4">
      <div class="container">
        <div class="row g-3">
          {{range .Features}}
          <div class="col-12 col-md-6 col-xl-3">
            <div class="d-flex align-items-center gap-2 bg-white rounded-3 p-3 h-100 shadow-sm">
              <span class="fs-4">{{.Icon}}</span>
              <p class="m-0 fw-semibold">{{.Title}}</p>
            </div>
          </div>
          {{end}}
        </div>
      </div>
    </section>

    <section class="container py-5">
      <h2 class="mb-4 fw-bold">Как это работает?</h2>
      <div class="row g-3">
        {{range .Steps}}
        <div class="col-12 col-md-6 col-xl-3">
          <article class="card h-100 border-0 shadow-sm">
            <div class="card-body">
              <span class="badge rounded-pill text-bg-success fs-6 mb-3 px-3 py-2">{{.Number}}</span>
              <p class="mb-0 fw-semibold">{{.Title}}</p>
            </div>
          </article>
        </div>
        {{end}}
      </div>
    </section>

    <section class="container pb-5">
      <h2 class="mb-4 fw-bold">Популярные товары</h2>
      <div class="row g-3">
        <div class="col-12 col-xl-9">
          <div class="row g-3">
            {{range .Products}}
            <div class="col-12 col-md-6 col-lg-3">
              <article class="card h-100 border-0 shadow-sm">
                <div class="product-thumb rounded-top"></div>
                <div class="card-body d-flex flex-column">
                  <h3 class="h6">{{.Name}}</h3>
                  <p class="small text-secondary mb-2">{{.Meta}}</p>
                  <p class="h5 fw-bold mb-3">{{.Price}}</p>
                  <button class="btn btn-success mt-auto">В корзину</button>
                </div>
              </article>
            </div>
            {{end}}
          </div>
        </div>

        <div class="col-12 col-xl-3">
          <aside class="card border-0 text-white shadow h-100 selector-card">
            <div class="card-body">
              <h3 class="h4 mb-3">Подберем систему полива за 1 минуту</h3>
              <div class="d-grid gap-2">
                <select class="form-select"><option>Площадь участка</option></select>
                <select class="form-select"><option>Тип растений</option></select>
                <select class="form-select"><option>Источник воды</option></select>
                <button class="btn btn-light fw-semibold">Получить решение</button>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="container pb-5">
      <h2 class="mb-4 fw-bold">Отзывы клиентов</h2>
      <div class="row g-3">
        {{range .Reviews}}
        <div class="col-12 col-md-6">
          <article class="card h-100 border-0 shadow-sm">
            <div class="card-body">
              <p class="text-warning fs-5 mb-2">★★★★★</p>
              <blockquote class="blockquote fs-6">{{.Text}}</blockquote>
              <p class="text-secondary mb-0">{{.Author}} · {{.Date}}</p>
            </div>
          </article>
        </div>
        {{end}}
      </div>
    </section>
  </main>

  <footer class="bg-dark text-light py-5 mt-auto">
    <div class="container">
      <div class="row g-4">
        <div class="col-12 col-md-5">
          <p class="fs-3 fw-bold text-uppercase mb-2">Aqua<span class="text-success">Green</span></p>
          <p class="text-light-emphasis">Интернет-магазин систем автоматического полива и комплектующих.</p>
        </div>
        <div class="col-6 col-md-3">
          <h4 class="h6">Каталог</h4>
          <ul class="list-unstyled small text-light-emphasis">
            <li>Капельный полив</li>
            <li>Дождеватели</li>
            <li>Контроллеры</li>
            <li>Трубы и фитинги</li>
          </ul>
        </div>
        <div class="col-6 col-md-4">
          <h4 class="h6">Контакты</h4>
          <ul class="list-unstyled small text-light-emphasis">
            <li>г. Москва, ул. Профсоюзная, 76</li>
            <li>+7 (495) 123-45-67</li>
            <li>Пн-Пт: 9:00-18:00</li>
          </ul>
        </div>
      </div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>
{{end}}
